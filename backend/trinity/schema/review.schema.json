{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trinity review verdict",
  "type": "object",
  "additionalProperties": false,
  "required": ["approved", "blocking_issues", "minor_notes", "reason"],
  "properties": {
    "approved": {
      "type": "boolean",
      "description": "Reviewer verdict. Only the reviewer sets this."
    },
    "blocking_issues": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Issues that must be fixed before approval."
    },
    "minor_notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Non-blocking suggestions."
    },
    "reason": {
      "type": "string",
      "description": "One-line summary of the verdict."
    }
  }
}
